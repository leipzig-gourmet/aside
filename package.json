{
  "name": "@leipzig-gourmet/aside",
  "version": "1.1.1",
  "type": "module",
  "description": "Apps Script IDE framework",
  "bin": "dist/src/index.js",
  "files": [
    "deploy-ui.mjs",
    "fix-animations.mjs",
    "dist/src",
    "dist/.gitignore-target",
    ".claspignore",
    ".editorconfig",
    "eslint.config.mjs",
    "jest.config.json",
    "LICENSE",
    ".prettierignore",
    ".prettierrc.json",
    "rollup.config.mjs",
    "tsconfig.json",
    "template",
    "template-ui"
  ],
  "repository": "https://github.com/leipzig-gourmet/aside.git",
  "main": "index.js",
  "scripts": {
    "clean": "rimraf build",
    "lint": "eslint --fix",
    "lint:staged": "lint-staged",
    "build": "npm run clean && npm run lint && tsc && npm run copy-files",
    "test": "jest test/ --detectOpenHandles",
    "copy-files": "ncp .gitignore dist/.gitignore-target",
    "prepare": "is-ci || husky init"
  },
  "keywords": [
    "typescript",
    "apps-script",
    "ide",
    "google"
  ],
  "engines": {
    "node": ">=24"
  },
  "author": "Leipzig Gourmet GmbH",
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/cross-spawn": "^6.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/google-apps-script": "^1.0.100",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.12.0",
    "@types/prompts": "^2.4.9",
    "@types/write-file-atomic": "^4.0.3",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "eslint": "10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "gts": "^7.0.0",
    "husky": "^9.1.7",
    "is-ci": "^4.1.0",
    "jest": "^30.3.0",
    "ncp": "^2.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "chalk": "^5.6.2",
    "cross-spawn": "^7.0.6",
    "fs-extra": "^11.3.4",
    "json5": "^2.2.3",
    "lint-staged": "^16.4.0",
    "meow": "^14.1.0",
    "prompts": "^2.4.2",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-prettier": "^4.1.1",
    "rollup-plugin-typescript2": "^0.36.0",
    "write-file-atomic": "^7.0.1"
  },
  "peerDependencies": {
    "typescript": ">=5"
  }
}
